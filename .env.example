# ---- RunPod ----
# Create an API key at https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key_here

# The saved RunPod TEMPLATE that boots ComfyUI with your Wan2.2 setup.
# Console -> Templates -> (your template) -> the id in the URL / details.
RUNPOD_TEMPLATE_ID=your_template_id

# The NETWORK VOLUME holding your Wan2.2 models.
# IMPORTANT: a network volume lives in ONE data center, so the pod must be
# created in that SAME data center (see RUNPOD_DATA_CENTER_ID below).
RUNPOD_NETWORK_VOLUME_ID=your_network_volume_id

# Must match the network volume's data center, e.g. EU-RO-1, US-OR-1, CA-MTL-1
RUNPOD_DATA_CENTER_ID=EU-RO-1

# Default GPU type id. Call GET /api/gpus (or check the console) for valid ids,
# e.g. "NVIDIA GeForce RTX 4090", "NVIDIA RTX A5000", "NVIDIA L40S".
RUNPOD_GPU_TYPE_ID=NVIDIA GeForce RTX 4090

# Cloud type: SECURE, COMMUNITY, or ALL
RUNPOD_CLOUD_TYPE=SECURE

# Optional image override. Leave blank to use the image baked into the template.
RUNPOD_IMAGE_NAME=

# Port ComfyUI listens on inside the pod (default 8188).
COMFY_PORT=8188

# Name prefix for pods this app creates.
POD_NAME=wan22-i2v
